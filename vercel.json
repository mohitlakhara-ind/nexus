{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(assets|favicon.ico|vite.svg|pwa-.*|manifest.webmanifest|sw.js|workbox-.*)(.*)",
      "dest": "/frontend/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
